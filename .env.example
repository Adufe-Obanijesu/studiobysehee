# Public site URL for canonical links, Open Graph, sitemap, and robots.
# Set in production. Use exactly one host (www OR apex), no trailing slash.
# NEXT_PUBLIC_SITE_URL=https://www.studiobysehee.com
# NEXT_PUBLIC_SITE_URL=https://studiobysehee.com

NEXT_PUBLIC_SITE_URL=

# Set to false on staging / pre-launch to block indexing (noindex + robots.txt disallow /).
# Omit or set true when the site should be indexed.
# NEXT_PUBLIC_SITE_INDEXABLE=false
